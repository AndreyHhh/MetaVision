# ============================================
.idea/
*.iws
*.iml
*.ipr
out/

# ============================================
# Исполняемые файлы — выкладывать в Releases, а не в код
# ============================================
*.exe
*.msi
*.deb
*.rpm

# ============================================
# Тестовые конфигурации 1С — КАТЕГОРИЧЕСКИ НЕ ВЫКЛАДЫВАТЬ
# ============================================
/test-configs/
/test-data/
*.cf
*.cfu
*.epf
*.erf

# ============================================
# Локальная база данных — НЕ ВЫКЛАДЫВАТЬ
# ============================================
/data/
*.db
*.sqlite
*.sqlite3

# ============================================
# Rust / Cargo — НЕ ВЫКЛАДЫВАТЬ
# ============================================
/.cargo/
/target/
Cargo.lock

# ============================================
# Локальные настройки и временные файлы
# ============================================
*.log
*.tmp
*.lock
/config.local.properties
/.env

